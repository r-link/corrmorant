Package: corrmorant
Type: Package
Title: Flexible Correlation Matrices Based on 'ggplot2'
Version: 0.1.0
Authors@R: c(
    person(
      given = "Roman M.",
      family = "Link",
      role = c("aut", "cre"),
      email = "roman.link@uni-wuerzburg.de"
    ),
    person(
      given = "Simon",
      family = "Dedman",
      role = "ctb"
    ))
Description:
    Extends 'ggplot2' by an automated framework for plots of correlation matrices
    that can be easily modified via regular 'ggplot2' syntax. In addition, it
    provides a large set of visualisation tools for exploratory data analysis
    based on correlation matrices.
Depends:
    R (>= 4.1.0),
    ggplot2 (>= 4.0.0)
Imports:
    rlang,
    grid,
    scales,
    dplyr (>= 0.8.3),
    tidyr (>= 1.0.0),
    magrittr,
    stats,
    methods
